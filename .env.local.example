# ─── Supabase ─────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key-aqui
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key-aqui

# ─── SMTP (envio de e-mail de confirmação) ────────────────────
# Exemplo com Gmail + Senha de App
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=seu-email@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx
SMTP_FROM=Salmazos RH <seu-email@gmail.com>

# ─── URL do site (usada nos redirecionamentos) ────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Cron Secret (protege endpoints /api/cron/*) ─────────────
# Gere com: openssl rand -hex 32
CRON_SECRET=seu-cron-secret-aqui

# ─── Clicksign (assinatura eletrônica — admissão) ─────────────
# Token de API v3 (Envelope), gerado no painel Clicksign.
CLICKSIGN_API_TOKEN=seu-token-aqui
# true = https://sandbox.clicksign.com/api/v3 · false = https://api.clicksign.com/api/v3
CLICKSIGN_SANDBOX=true
# "HMAC SHA256 Secret" gerado ao cadastrar o webhook no painel Clicksign — é DIFERENTE
# do CLICKSIGN_API_TOKEN. Usado para validar o header Content-Hmac dos webhooks recebidos.
CLICKSIGN_WEBHOOK_SECRET=seu-webhook-secret-aqui
